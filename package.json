{
  "name": "@cogentic-co/ds",
  "version": "0.5.5",
  "description": "Cogentic Design System — UI components for building modern compliance applications",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles.css": "./src/styles/globals.css",
    "./animations/*": {
      "import": {
        "types": "./dist/animations/*.d.ts",
        "default": "./dist/animations/*.js"
      }
    },
    "./blocks/*": {
      "import": {
        "types": "./dist/blocks/*.d.ts",
        "default": "./dist/blocks/*.js"
      }
    },
    "./charts": {
      "import": {
        "types": "./dist/charts.d.ts",
        "default": "./dist/charts.js"
      }
    },
    "./workflow": {
      "import": {
        "types": "./dist/workflow.d.ts",
        "default": "./dist/workflow.js"
      }
    }
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "sideEffects": [
    "*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://cogentic.co",
  "repository": {
    "type": "git",
    "url": "https://github.com/cogentic-co/ds.git"
  },
  "bugs": {
    "url": "https://github.com/cogentic-co/ds/issues"
  },
  "keywords": [
    "design-system",
    "react",
    "components",
    "tailwindcss",
    "typescript",
    "ui",
    "compliance",
    "nextjs",
    "base-ui",
    "cogentic"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "generate:props": "node --import tsx scripts/generate-props.ts",
    "build:pkg": "tsup",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "size": "size-limit",
    "size:check": "size-limit --json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "changeset": "changeset",
    "version:bump": "changeset version",
    "prepublishOnly": "pnpm build:pkg"
  },
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0",
    "recharts": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@xyflow/react": {
      "optional": true
    },
    "recharts": {
      "optional": true
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.575.0",
    "motion": "^12.34.3",
    "react-day-picker": "^9.13.2",
    "react-resizable-panels": "^4.6.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "tw-animate-css": "^1.4.0",
    "@biomejs/biome": "^2.4.6",
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jscodeshift": "^17.3.0",
    "@types/node": "^25.3.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@xyflow/react": "^12.8.2",
    "jscodeshift": "^17.3.0",
    "jsdom": "^28.1.0",
    "next": "16.1.6",
    "react-docgen-typescript": "^2.4.0",
    "shiki": "^4.0.2",
    "size-limit": "^12.0.1",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
